# MongoDB (local for dev, Atlas connection string for cloud deploy)
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=whatsapp_agent

# Meta WhatsApp Cloud API
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_VERIFY_TOKEN=my_secret_verify_token_123
META_APP_SECRET=your_app_secret_here

# Groq — PRIMARY reasoning LLM with tool calling (console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — used for vision (inbound images, catalog auto-describe) (aistudio.google.com)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.0-flash

# Dashboard login (single admin password gate)
ADMIN_PASSWORD=kredai_admin

# App base URL (localhost or ngrok for dev, Render URL for prod)
APP_BASE_URL=http://localhost:8000
